{
  "version": 2,
  "builds": [
    {
      "src": "api/index.ts",
      "use": "@vercel/node"
    },
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/index.ts" },
    { "src": "/auth/(.*)", "dest": "/api/index.ts" },
    { "src": "/friends(.*)", "dest": "/api/index.ts" },
    { "src": "/leetcode/(.*)", "dest": "/api/index.ts" },
    { "src": "/leaderboard(.*)", "dest": "/api/index.ts" },
    { "src": "/contests(.*)", "dest": "/api/index.ts" },
    { "src": "/compare(.*)", "dest": "/api/index.ts" },
    { "src": "/insights(.*)", "dest": "/api/index.ts" },
    { "src": "/dashboard(.*)", "dest": "/api/index.ts" },
    { "src": "/competition(.*)", "dest": "/api/index.ts" },
    { "src": "/challenges(.*)", "dest": "/api/index.ts" },
    { "src": "/health", "dest": "/api/index.ts" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
