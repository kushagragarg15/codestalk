PORT=4000
MONGODB_URI=mongodb://127.0.0.1:27017/codestalk
JWT_SECRET=dev-only-change-me-please-use-16chars-minimum-secret
JWT_EXPIRES_IN=7d
CLIENT_ORIGIN=http://localhost:5173
# Data source: alfa (REST, documented) | graphql (direct LeetCode GraphQL)
LEETCODE_PROVIDER=alfa
ALFA_LEETCODE_API_URL=https://alfa-leetcode-api.onrender.com
LEETCODE_GRAPHQL_URL=https://leetcode.com/graphql
# Optional: in-memory cache TTL seconds (Mongo-backed entries use their own TTL)
DEFAULT_CACHE_TTL_SEC=300
# Rate limit: max requests per IP per window (LeetCode proxy)
LEETCODE_PROXY_MAX=60
LEETCODE_PROXY_WINDOW_MS=60000
# Email (optional — reminders disabled if unset)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@codestalk.local
REMINDER_CRON=0 18 * * *
